---
export interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  ogImage?: string;
}

const {
  title,
  description,
  canonicalPath,
  ogImage = '/og-image.png'
} = Astro.props;

const canonicalUrl = canonicalPath 
  ? new URL(canonicalPath, Astro.site || 'https://buildhire.com.au' ) 
  : new URL(Astro.url.pathname, Astro.site || 'https://buildhire.com.au' );

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "BuildHire",
  "url": "https://buildhire.com.au",
  "logo": "https://buildhire.com.au/favicon.png",
  "description": "Sydney's top-rated excavator and construction equipment hire company. Mini excavator dry hire from $200/day with next-day delivery across NSW.",
  "telephone": "+611300157882",
  "email": "info@buildhire.com.au",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Sydney",
    "addressRegion": "NSW",
    "addressCountry": "AU"
  },
  "areaServed": {
    "@type": "State",
    "name": "New South Wales",
    "containsPlace": [
      { "@type": "City", "name": "Sydney" },
      { "@type": "City", "name": "Newcastle" },
      { "@type": "City", "name": "Wollongong" },
      { "@type": "City", "name": "Central Coast" }
    ]
  },
  "sameAs": [
    "https://www.facebook.com/people/Build-Hire/61586999393373/",
    "https://www.instagram.com/buildhiresydney/"
  ],
  "priceRange": "$$",
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
      "opens": "06:00",
      "closes": "20:00"
    }
  ],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5.0",
    "reviewCount": "6",
    "bestRating": "5",
    "worstRating": "1"
  }
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "BuildHire",
  "image": "https://buildhire.com.au/og-image.png",
  "url": "https://buildhire.com.au",
  "telephone": "+611300157882",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Sydney",
    "addressRegion": "NSW",
    "postalCode": "2000",
    "addressCountry": "AU"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -33.8688,
    "longitude": 151.2093
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
      "opens": "06:00",
      "closes": "20:00"
    }
  ],
  "priceRange": "$$",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5.0",
    "reviewCount": "6",
    "bestRating": "5",
    "worstRating": "1"
  },
  "description": "Sydney's top-rated excavator and construction equipment hire. Mini excavator dry hire from $200/day with next-day delivery and collection across NSW."
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "BuildHire",
  "url": "https://buildhire.com.au",
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "https://buildhire.com.au/?s={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
};
---

<!-- Primary Meta Tags -->
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />

<!-- Performance: Preload critical assets -->
<link rel="preload" href="/video/hero-bg.mp4" as="video" type="video/mp4" />
<link rel="dns-prefetch" href="https://wa.me" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
<meta name="author" content="BuildHire" />
<meta name="theme-color" content="#f5a623" />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(ogImage, Astro.site || 'https://buildhire.com.au' )} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalUrl} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(ogImage, Astro.site || 'https://buildhire.com.au' )} />

<!-- Schema.org Markup -->
<script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
