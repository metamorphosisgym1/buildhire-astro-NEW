---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header';
import Hero from '../components/Hero';
import StatsBar from '../components/StatsBar';
import BookingCalculator from '../components/BookingCalculator';
import EquipmentGrid from '../components/EquipmentGrid';
import Testimonials from '../components/Testimonials';
import DeliveryRegions from '../components/DeliveryRegions';
import Features from '../components/Features';
import FAQ from '../components/FAQ';
import Footer from '../components/Footer';
import ChatWidget from '../components/ChatWidget';
import StickyBottomBar from '../components/StickyBottomBar';

// FAQ Schema for AEO
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What areas of Sydney do you deliver to & collect from?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We deliver & collect across all of Greater Sydney, including the CBD, Eastern Suburbs, Inner West, North Shore, Northern Beaches, Western Sydney, and the Hills District. Contact us to confirm delivery & collection to your specific site."
      }
    },
    {
      "@type": "Question",
      "name": "How quickly can you deliver & collect equipment?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We offer next-day delivery & collection for bookings placed before 12pm. For urgent requirements, call 1300 157 882 to discuss same-day options."
      }
    },
    {
      "@type": "Question",
      "name": "What is your minimum hire period?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our minimum hire period is one day. We offer daily, weekly, and monthly rates with significant discounts for longer-term hires."
      }
    },
    {
      "@type": "Question",
      "name": "Do I need a licence to operate a mini excavator?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "In NSW, no licence is required to operate a mini excavator under 10 tonnes on private property. For public roads or worksites, a High Risk Work Licence (HRWL) may be required."
      }
    },
    {
      "@type": "Question",
      "name": "What is included in the hire price?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our dry hire rates include the machine and standard bucket. Delivery & collection is charged separately. Fuel, insurance, and operator costs are not included in the base rate."
      }
    },
    {
      "@type": "Question",
      "name": "How do I book excavator hire in Sydney?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "You can book instantly using our online booking calculator. Select your equipment, choose your hire dates, enter your site details, and pay a $200 refundable bond to confirm. Alternatively, call 1300 157 882 or WhatsApp for a custom quote."
      }
    }
  ]
};

// HowTo Schema for AEO
const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to Hire an Excavator in Sydney",
  "description": "Step-by-step guide to hiring an excavator or construction equipment from BuildHire in Sydney, NSW.",
  "totalTime": "PT5M",
  "step": [
    {
      "@type": "HowToStep",
      "name": "Choose your equipment",
      "text": "Browse our fleet of excavators, mini dumpers, tipper trucks, and attachments. Select the machine that suits your project.",
      "position": 1
    },
    {
      "@type": "HowToStep",
      "name": "Select your hire dates",
      "text": "Choose your start and end dates using our booking calculator. We offer daily, weekly, and monthly rates.",
      "position": 2
    },
    {
      "@type": "HowToStep",
      "name": "Enter your site details",
      "text": "Provide your delivery address and contact information so we can arrange next-day delivery and collection.",
      "position": 3
    },
    {
      "@type": "HowToStep",
      "name": "Pay the $200 refundable bond",
      "text": "Secure your booking with a $200 refundable bond via Stripe's secure checkout. The hire balance is due on delivery.",
      "position": 4
    },
    {
      "@type": "HowToStep",
      "name": "Receive your equipment",
      "text": "We deliver your equipment to your site, typically next-day for bookings placed before 12pm.",
      "position": 5
    }
  ]
};

// Speakable Schema for AEO / Voice Search
const speakableSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Excavator Hire Sydney | Mini Excavator Dry Hire — BuildHire",
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": ["h1", "h2", "#faq-heading", ".speakable"]
  },
  "url": "https://buildhire.com.au/"
};

// Service Schema
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Excavator Hire Sydney",
  "provider": {
    "@type": "LocalBusiness",
    "name": "BuildHire",
    "url": "https://buildhire.com.au"
  },
  "areaServed": {
    "@type": "State",
    "name": "New South Wales"
  },
  "description": "Mini excavator dry hire from $200/day with next-day delivery and collection across Sydney and NSW. No hidden fees, transparent pricing.",
  "offers": {
    "@type": "Offer",
    "priceCurrency": "AUD",
    "price": "200",
    "priceSpecification": {
      "@type": "UnitPriceSpecification",
      "price": "200",
      "priceCurrency": "AUD",
      "unitText": "DAY"
    }
  }
};
---

<Layout
  title="Excavator Hire Sydney | Mini Excavator Dry Hire — BuildHire"
  description="Sydney's top-rated excavator hire. Mini excavator dry hire from $200/day with next-day delivery. Book online instantly — no hidden fees."
  canonicalPath="/"
  ogImage="/og-image.png"
>
  <!-- Additional page-specific structured data -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(speakableSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <div class="min-h-screen pb-20">
    <Header client:load />
    <Hero client:load />
    <StatsBar client:visible />
    <BookingCalculator client:visible />
    <EquipmentGrid client:visible />
    <Testimonials client:visible />
    <DeliveryRegions client:visible />
    <Features client:visible />
    <FAQ client:visible />
    <Footer client:visible />
    <ChatWidget client:load />
    <StickyBottomBar client:load />
  </div>
</Layout>
