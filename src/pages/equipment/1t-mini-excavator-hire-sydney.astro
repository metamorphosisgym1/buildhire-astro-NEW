---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header';
import Footer from '../../components/Footer';
import ChatWidget from '../../components/ChatWidget';
import StickyBottomBar from '../../components/StickyBottomBar';
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "1T Mini Excavator Hire Sydney",
  "provider": { "@type": "LocalBusiness", "name": "BuildHire", "url": "https://buildhire.com.au", "telephone": "+611300157882", "address": { "@type": "PostalAddress", "addressLocality": "Sydney", "addressRegion": "NSW", "addressCountry": "AU" } },
  "areaServed": { "@type": "State", "name": "New South Wales" },
  "description": "1T Kubota U10-5 mini excavator dry hire in Sydney from $200/day. Ultra-compact with foldable ROPS for indoor and tight-access work. Next-day delivery across NSW.",
  "offers": { "@type": "Offer", "priceCurrency": "AUD", "price": "200" }
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How much does it cost to hire a 1T mini excavator in Sydney?", "acceptedAnswer": { "@type": "Answer", "text": "BuildHire's 1T Kubota U10-5 starts from $200/day incl GST. Delivery and collection is $110. Call 1300 157 882 for weekly rates." } },
    { "@type": "Question", "name": "Do I need a licence to operate a 1T mini excavator in NSW?", "acceptedAnswer": { "@type": "Answer", "text": "No licence is required on private property in NSW. On a registered worksite a High Risk Work Licence may be required." } },
    { "@type": "Question", "name": "Can the Kubota U10-5 work indoors?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. The foldable ROPS allows the machine to pass through standard doorways and work inside warehouses, garages, and basements." } },
    { "@type": "Question", "name": "What is the difference between the 0.8T and 1T mini excavator?", "acceptedAnswer": { "@type": "Answer", "text": "The 1T Kubota U10-5 offers greater dig depth (1,800mm vs 1,510mm ), more breakout force (1,060kgf), and a foldable ROPS for indoor work." } },
    { "@type": "Question", "name": "How quickly can BuildHire deliver in Sydney?", "acceptedAnswer": { "@type": "Answer", "text": "Next-day delivery for bookings before 12pm. Same-day may be available — call 1300 157 882." } }
  ]
};
---
<Layout title="1T Mini Excavator Hire Sydney | Kubota U10-5 From $200/day — BuildHire" description="Hire a 1T Kubota U10-5 mini excavator in Sydney from $200/day. Foldable ROPS for indoor and tight-access work. Next-day delivery across NSW." canonicalPath="/equipment/1t-mini-excavator-hire-sydney" ogImage="/og-image.png">
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <div class="min-h-screen pb-20">
    <Header client:load />
    <section class="bg-[var(--color-bg)] pt-28 pb-16">
      <div class="max-w-5xl mx-auto px-6">
        <div class="text-center mb-10">
          <span class="inline-block bg-[var(--color-primary)] text-white text-sm font-semibold px-4 py-1 rounded-full mb-4">Available Now</span>
          <h1 class="text-4xl md:text-5xl font-bold text-[var(--color-text)] mb-4">1T Mini Excavator Hire Sydney</h1>
          <p class="text-xl text-[var(--color-text-muted)] max-w-2xl mx-auto">Kubota U10-5 — ultra-compact with foldable ROPS for indoor and tight-access work. From <strong class="text-[var(--color-primary)]">$200/day</strong> incl GST. Next-day delivery across Sydney and NSW.</p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
            <a href="/#booking" class="bg-[var(--color-primary)] text-white font-bold px-8 py-4 rounded-lg hover:opacity-90 transition text-lg">Book Now — Instant Pricing →</a>
            <a href="https://wa.me/611300157882" target="_blank" rel="noopener" class="border-2 border-[var(--color-primary )] text-[var(--color-primary)] font-bold px-8 py-4 rounded-lg hover:bg-[var(--color-primary)] hover:text-white transition text-lg">WhatsApp for a Quote</a>
          </div>
        </div>
        <div class="rounded-2xl overflow-hidden shadow-xl max-w-3xl mx-auto">
          <img src="/assets/kubota-u10-5-branded.png" alt="Kubota U10-5 1T Mini Excavator Hire Sydney — BuildHire" class="w-full object-cover" width="1200" height="675" loading="eager" />
        </div>
      </div>
    </section>
    <section class="bg-white py-16">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="text-3xl font-bold text-[var(--color-text)] mb-10 text-center">Machine Specs and Pricing</h2>
        <div class="grid md:grid-cols-2 gap-10">
          <div class="bg-[var(--color-bg)] rounded-2xl p-8">
            <h3 class="text-xl font-bold text-[var(--color-text)] mb-6">Kubota U10-5 Specifications</h3>
            <div class="space-y-4">
              {[{label:"Operating Weight",value:"1,200 kg"},{label:"Engine",value:"Kubota D722-E4 — 10.3 HP (7.7 kW)"},{label:"Max Dig Depth",value:"1,800 mm"},{label:"Max Dig Radius",value:"3,380 mm"},{label:"Max Dump Height",value:"2,210 mm"},{label:"Transport Width (Std)",value:"990 mm"},{label:"Transport Width (Narrow)",value:"750 mm"},{label:"Bucket Breakout Force",value:"1,060 kgf"},{label:"Travel Speed",value:"2.0 / 4.0 km/h"},{label:"Tail Swing",value:"Zero"},{label:"ROPS",value:"Foldable — fits through doorways"}].map(item => (
                <div class="flex justify-between items-center border-b border-gray-200 pb-3">
                  <span class="text-[var(--color-text-muted)] text-sm">{item.label}</span>
                  <span class="font-semibold text-[var(--color-text)] text-sm text-right">{item.value}</span>
                </div>
              ))}
            </div>
          </div>
          <div class="bg-[var(--color-bg)] rounded-2xl p-8">
            <h3 class="text-xl font-bold text-[var(--color-text)] mb-6">Hire Rates</h3>
            <div class="space-y-5">
              <div class="flex justify-between items-center border-b border-gray-200 pb-4"><span class="text-[var(--color-text-muted)]">Daily Rate</span><span class="text-2xl font-bold text-[var(--color-primary)]">$200/day</span></div>
              <div class="flex justify-between items-center border-b border-gray-200 pb-4"><span class="text-[var(--color-text-muted)]">Weekly Rate</span><span class="text-xl font-bold text-[var(--color-text)]">Call for quote</span></div>
              <div class="flex justify-between items-center border-b border-gray-200 pb-4"><span class="text-[var(--color-text-muted)]">Delivery and Collection</span><span class="text-xl font-bold text-[var(--color-text)]">$110</span></div>
              <div class="flex justify-between items-center"><span class="text-[var(--color-text-muted)]">Bond (refundable)</span><span class="text-xl font-bold text-[var(--color-text)]">$200</span></div>
            </div>
            <p class="text-xs text-[var(--color-text-muted)] mt-4">All prices include GST. Fuel not included.</p>
          </div>
        </div>
      </div>
    </section>
    <section class="bg-[var(--color-bg)] py-16">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="text-3xl font-bold text-[var(--color-text)] mb-8 text-center">Why the Kubota U10-5?</h2>
        <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">
          {[{icon:"🚪",title:"Works Indoors",desc:"Foldable ROPS lets the U10-5 pass through standard doorways — ideal for warehouse, garage, and basement work."},{icon:"📐",title:"Variable Track Width",desc:"Tracks retract from 990mm to 750mm for ultra-narrow access through gates and tight sites."},{icon:"💪",title:"1,060 kgf Breakout Force",desc:"More digging power than a 0.8T — handles compacted soil, clay, and light rock."},{icon:"🔄",title:"Zero Tail Swing",desc:"Work right up against walls and fences without risk of damage."},{icon:"🌙",title:"LED Boom Work Light",desc:"Standard LED light for early morning, evening, and low-light conditions."},{icon:"🔧",title:"Easy Maintenance",desc:"Full-opening engine cover and protected hydraulic ports for fast servicing."}].map(item => (
            <div class="bg-white rounded-xl p-6 shadow-sm">
              <div class="text-3xl mb-3">{item.icon}</div>
              <h3 class="font-bold text-[var(--color-text)] mb-2">{item.title}</h3>
              <p class="text-sm text-[var(--color-text-muted)]">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
    <section class="bg-white py-16">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="text-3xl font-bold text-[var(--color-text)] mb-10 text-center">Frequently Asked Questions</h2>
        <div class="space-y-4">
          {[{q:"How much does it cost to hire a 1T mini excavator in Sydney?",a:"BuildHire's 1T Kubota U10-5 starts from $200/day incl GST. Delivery and collection is $110. Call 1300 157 882 for weekly rates."},{q:"Do I need a licence to operate a 1T mini excavator in NSW?",a:"No licence is required on private property in NSW. On a registered worksite a High Risk Work Licence may be required."},{q:"Can the Kubota U10-5 work indoors?",a:"Yes. The foldable ROPS allows the machine to pass through standard doorways and work inside warehouses, garages, and basements."},{q:"What is the difference between the 0.8T and 1T mini excavator?",a:"The 1T Kubota U10-5 offers greater dig depth (1,800mm vs 1,510mm), more breakout force (1,060kgf), and a foldable ROPS for indoor work."},{q:"How quickly can BuildHire deliver in Sydney?",a:"Next-day delivery for bookings before 12pm. Same-day may be available — call 1300 157 882."}].map(item => (
            <details class="bg-[var(--color-bg)] rounded-xl p-6 shadow-sm group">
              <summary class="font-semibold text-[var(--color-text)] cursor-pointer list-none flex justify-between items-center">{item.q}<span class="text-[var(--color-primary)] ml-4 text-xl group-open:rotate-45 transition-transform">+</span></summary>
              <p class="mt-4 text-[var(--color-text-muted)] text-sm leading-relaxed">{item.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
    <section class="bg-[var(--color-primary)] py-16">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <h2 class="text-3xl font-bold text-white mb-4">Ready to Book Your 1T Mini Excavator?</h2>
        <p class="text-white/80 mb-8 text-lg">Book online in 60 seconds or call us for an instant quote. Next-day delivery across Sydney and NSW.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/#booking" class="bg-white text-[var(--color-primary)] font-bold px-8 py-4 rounded-lg hover:bg-gray-100 transition text-lg">Book Online Now →</a>
          <a href="tel:1300157882" class="border-2 border-white text-white font-bold px-8 py-4 rounded-lg hover:bg-white hover:text-[var(--color-primary)] transition text-lg">Call 1300 157 882</a>
        </div>
      </div>
    </section>
    <Footer client:visible />
    <ChatWidget client:load />
    <StickyBottomBar client:load />
  </div>
</Layout>
